{
  "name": "better-soundcloud-feed",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vp build --watch --mode development",
    "build": "vp build",
    "build:dev": "vp build --mode development",
    "check": "vp check",
    "fmt": "vp fmt",
    "test": "vp test",
    "test:coverage": "vp test --coverage",
    "typecheck": "tsc --noEmit",
    "check:unused": "knip --production && knip",
    "check:unused:prod": "knip --production",
    "check:unused:full": "knip",
    "generate-icons": "node scripts/generate-icons.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@logtape/logtape": "^2.0.4",
    "@preact/signals": "^2.9.0",
    "preact": "^10.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "chrome-types": "^0.1.327",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "knip": "^6.0.1",
    "lint-staged": "^16.4.0",
    "sharp": "^0.34.5",
    "type-fest": "^5.5.0",
    "typescript": "^5.9.3",
    "universal-ai-config": "^1.11.2",
    "vite-plus": "^0.1.13"
  },
  "lint-staged": {
    "*.{js,ts,mjs,mts,cjs,cts}": [
      "vp fmt --write",
      "vp lint"
    ]
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest"
    }
  }
}
