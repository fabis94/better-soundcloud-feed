{
  "name": "soundcloud-feed-filter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp build --watch",
    "build": "vp build",
    "check": "vp check",
    "fmt": "vp fmt",
    "test": "vp test",
    "test:coverage": "vp test --coverage",
    "typecheck": "tsc --noEmit",
    "check:unused": "knip --production && knip",
    "check:unused:prod": "knip --production",
    "check:unused:full": "knip",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "chrome-types": "^0.1.327",
    "jsdom": "^29.0.1",
    "knip": "^6.0.1",
    "sharp": "^0.34.5",
    "type-fest": "^5.5.0",
    "typescript": "^5.9.3",
    "universal-ai-config": "^1.11.2",
    "vite-plus": "^0.1.13"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest"
    }
  },
  "dependencies": {
    "@logtape/logtape": "^2.0.4"
  }
}
